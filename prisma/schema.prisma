generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String?
  passwordHash String?
  role         UserRole  @default(TEAM)
  expertId     String?   @unique
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  accounts     Account[]
  sessions     Session[]
  expert       Expert?   @relation(fields: [expertId], references: [id])

  @@index([deletedAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Expert {
  id        String            @id @default(cuid())
  name      String
  email     String            @unique
  tags      String[]
  bio       String?
  deletedAt DateTime?
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  sessions  AnalysisSession[]
  user      User?
}

model Course {
  id          String    @id @default(cuid())
  name        String
  description String?
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  batches     Batch[]
  modules     Module[]
}

model Module {
  id        String        @id @default(cuid())
  name      String
  order     Int           @default(0)
  courseId  String
  deletedAt DateTime?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  course    Course        @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sessions  SessionNote[]

  @@index([deletedAt])
  @@index([courseId])
}

model SessionNote {
  id               String            @id @default(cuid())
  name             String
  content          String?
  phase            String?
  prerequisites    String?
  keyTopics        String[]
  expertGaps       String?
  moduleId         String
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  analysisSessions AnalysisSession[]
  module           Module            @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  @@index([deletedAt])
  @@index([moduleId])
}

model AnalysisSession {
  id                         String                  @id @default(cuid())
  name                       String
  expertId                   String
  sessionNoteId              String?
  transcriptPath             String?
  transcriptRaw              String?
  transcript_clean           String?
  scheduledDuration          Int?
  v3Status                   PipelineStatus          @default(PENDING)
  v3Progress                 String?
  v3Error                    String?
  heartbeat                  DateTime?
  batchId                    String?
  deletedAt                  DateTime?
  createdAt                  DateTime                @default(now())
  updatedAt                  DateTime                @updatedAt
  pipeline_stage             String                  @default("UPLOADED")
  next_action_at             DateTime                @default(now())
  stage_attempts             Json                    @default("{}")
  chapters_json              Json?
  transcript_quality         String?                 @default("Good")
  transcript_quality_signals Json?                   @default("[]")
  schema_version             String?                 @default("v1")
  zoom_recording_id          String?
  zoom_download_url          String?
  videoUrl                   String?
  transcriptUrl              String?
  source                     String?                 @default("manual")
  tier                       String                  @default("TIER1")
  tier1Result                Json?
  AnalysisChapterResult      AnalysisChapterResult[]
  batch                      Batch?                  @relation(fields: [batchId], references: [id])
  expert                     Expert                  @relation(fields: [expertId], references: [id])
  sessionNote                SessionNote?            @relation(fields: [sessionNoteId], references: [id])
  v2Analysis                 AnalysisV2?

  @@index([deletedAt])
  @@index([expertId])
  @@index([next_action_at])
  @@index([pipeline_stage])
}

model AnalysisV2 {
  id                    String          @id @default(cuid())
  sessionId             String          @unique
  status                String          @default("pending")
  progress              String?
  sessionFlow           Json?
  pillar6A              Json?
  pillar6B              Json?
  pillar6C              Json?
  epochSummaries        Json?
  verifierResult        Json?
  costEstimate          Float?
  error                 String?
  session_flags         Json?
  accuracy_issues       Json?
  teaching_depth_map    Json?
  pacing_map            Json?
  engagement_by_chapter Json?
  confusion_summary     Json?
  unresolved_doubts     Json?
  topics_missed         Json?
  context_setup         Json?
  topics_covered        Json?
  full_synthesis        Json?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  schema_version        String?         @default("v1")
  session               AnalysisSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Batch {
  id          String            @id @default(cuid())
  name        String
  description String?
  courseId    String?
  deletedAt   DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  sessions    AnalysisSession[]
  course      Course?           @relation(fields: [courseId], references: [id])
}

model AnalysisChapterResult {
  id              String          @id
  session_id      String
  chapter_index   Int
  result          Json
  needs_review    Boolean         @default(false)
  review_reasons  Json?           @default("[]")
  created_at      DateTime?       @default(now()) @db.Timestamptz(6)
  AnalysisSession AnalysisSession @relation(fields: [session_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([session_id, chapter_index])
  @@index([session_id], map: "idx_chapter_result_session")
}

enum UserRole {
  ADMIN
  TEAM
  EXPERT
}

enum PipelineStatus {
  PENDING
  PREPROCESSING
  EXTRACTING
  AGGREGATING
  SYNTHESISING
  COMPLETE
  FAILED
}
